NEXT_PUBLIC_NANCY_API_URL=http://localhost:8765
NEXT_PUBLIC_NANCY_WS_URL=ws://localhost:8765/ws
NEXT_PUBLIC_RESTAURANT_TIMEZONE=Africa/Lagos
NEXT_PUBLIC_RESTAURANT_NAME=XYZ Restaurant
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Vercel / production: point at your deployed Python voice_agent host
# NANCY_BACKEND_URL=https://your-python-host.example.com

# Local dev: clicking "Talk to Nancy" auto-starts the Python backend (no separate terminal).
# Set NANCY_AUTO_START=0 to disable. Requires `uv` on PATH.
# NANCY_BACKEND_PATH=/absolute/path/to/voice_agent
