DEEPGRAM_API_KEY=
# End call after this many seconds of silence once Nancy has finished speaking (default: 60)
SILENCE_TIMEOUT_SECONDS=60
OPENAI_API_KEY=
# Optional — enables AI call summaries on the admin page (falls back to rule-based if unset)
OPENAI_SUMMARY_MODEL=gpt-4o-mini
GOOGLE_CALENDAR_API_KEY=
GOOGLE_CALENDAR_ID=primary
GOOGLE_CALENDAR_TIMEZONE=Africa/Lagos
APP_TIMEZONE=Africa/Lagos
# Nancy uses this for "today", "tonight", and booking dates (falls back to GOOGLE_CALENDAR_TIMEZONE)
RESTAURANT_TIMEZONE=Africa/Lagos
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
